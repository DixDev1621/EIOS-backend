# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# === Supabase ===
# Create a free project at https://supabase.com, then Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# === NASA FIRMS (fire detections) ===
# Free instant signup: https://firms.modis.gov/api/map_key/
NASA_FIRMS_MAP_KEY=

# === WAQI (optional ground-station cross-check) ===
# Free token: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# === Cache / rate limiting ===
CACHE_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=120

# === Open-Meteo request throttling & retry (all have safe defaults) ===
OPEN_METEO_MAX_CONCURRENT_REQUESTS=5
OPEN_METEO_MAX_RETRIES=3
OPEN_METEO_RETRY_BASE_SECONDS=1.0
